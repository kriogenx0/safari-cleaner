{
    "manifest_version": 3,
    "name": "Safari Swipe",
    "version": "1.0",
    "description": "Review your bookmarks — keep or delete, one at a time.",
    "permissions": ["bookmarks", "storage", "scripting", "tabs"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_icon": {
            "48":  "images/icon-48.png",
            "96":  "images/icon-96.png",
            "128": "images/icon-128.png",
            "256": "images/icon-256.png"
        },
        "default_title": "Review bookmarks"
    },
    "icons": {
        "48":  "images/icon-48.png",
        "96":  "images/icon-96.png",
        "128": "images/icon-128.png",
        "256": "images/icon-256.png"
    }
}
